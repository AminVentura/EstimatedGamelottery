rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function drawingKeysOk() {
      return request.resource.data.keys().hasOnly(['mainNumbers', 'date', 'userId', 'createdAt', 'special']);
    }

    function dateStringOk() {
      return request.resource.data.date is string
             && request.resource.data.date.size() == 10
             && request.resource.data.date.matches('^[0-9]{4}-[0-9]{2}-[0-9]{2}$');
    }

    function mainNumbersSizeOk() {
      return (request.resource.data.mainNumbers is string
              && request.resource.data.mainNumbers.size() > 0
              && request.resource.data.mainNumbers.size() <= 220)
             || (request.resource.data.mainNumbers is list
                 && request.resource.data.mainNumbers.size() > 0
                 && request.resource.data.mainNumbers.size() <= 25);
    }

    function hasDrawingFields() {
      return drawingKeysOk()
             && request.resource.data.keys().hasAll(['mainNumbers', 'date', 'userId', 'createdAt'])
             && dateStringOk()
             && request.resource.data.createdAt is timestamp
             && request.resource.data.userId is string
             && request.resource.data.userId == request.auth.uid
             && mainNumbersSizeOk()
             && (request.resource.data.special == null
                 || request.resource.data.special is int);
    }

    function isValidDrawing() {
      return isSignedIn() && hasDrawingFields();
    }

    function isOwner() {
      return isSignedIn() && resource.data.userId == request.auth.uid;
    }

    function userStatsWriteOk(userId) {
      return isSignedIn()
             && request.auth.uid == userId
             && request.resource.data.keys().size() <= 48;
    }

    match /artifacts/EstimatedGamelottery-app/public/data/powerball_drawings/{docId} {
      allow read: if true;
      allow create: if isValidDrawing();
      allow update: if false;
      allow delete: if isOwner();
    }

    match /artifacts/EstimatedGamelottery-app/public/data/millionaireforlife_drawings/{docId} {
      allow read: if true;
      allow create: if isValidDrawing();
      allow update: if false;
      allow delete: if isOwner();
    }

    match /artifacts/EstimatedGamelottery-app/public/data/megamillions_drawings/{docId} {
      allow read: if true;
      allow create: if isValidDrawing();
      allow update: if false;
      allow delete: if isOwner();
    }

    match /artifacts/EstimatedGamelottery-app/public/data/pick10_drawings/{docId} {
      allow read: if true;
      allow create: if isValidDrawing();
      allow update: if false;
      allow delete: if isOwner();
    }
    match /artifacts/EstimatedGamelottery-app/public/data/take5day_drawings/{docId} {
      allow read: if true;
      allow create: if isValidDrawing();
      allow update: if false;
      allow delete: if isOwner();
    }
    match /artifacts/EstimatedGamelottery-app/public/data/take5eve_drawings/{docId} {
      allow read: if true;
      allow create: if isValidDrawing();
      allow update: if false;
      allow delete: if isOwner();
    }
    match /artifacts/EstimatedGamelottery-app/public/data/win4day_drawings/{docId} {
      allow read: if true;
      allow create: if isValidDrawing();
      allow update: if false;
      allow delete: if isOwner();
    }
    match /artifacts/EstimatedGamelottery-app/public/data/win4eve_drawings/{docId} {
      allow read: if true;
      allow create: if isValidDrawing();
      allow update: if false;
      allow delete: if isOwner();
    }

    match /artifacts/EstimatedGamelottery-app/public/data/user_stats/{userId} {
      allow read: if true;
      allow create: if userStatsWriteOk(userId);
      allow update: if userStatsWriteOk(userId);
      allow delete: if isSignedIn() && request.auth.uid == userId;
    }

    // ── Sports Feedback Votes ────────────────────────────────────────────
    // Doc ID = {uid}_{predId} — enforces one vote per user per prediction.
    match /sportsVotes/{voteId} {
      allow read: if true;
      allow create: if isSignedIn()
        && request.resource.data.uid == request.auth.uid
        && voteId == request.auth.uid + '_' + request.resource.data.predId
        && request.resource.data.keys().hasOnly(['uid','predId','sport','vote','createdAt','date'])
        && (request.resource.data.vote == 'yes' || request.resource.data.vote == 'no')
        && request.resource.data.predId is string
        && request.resource.data.predId.size() <= 64
        && request.resource.data.sport is string;
      allow update: if false;
      allow delete: if false;
    }

    // ── Global Accuracy Aggregate ────────────────────────────────────────
    match /sportsAccuracy/{docId} {
      allow read: if true;
      allow write: if false; // Cloud Function trigger only
    }

    // ── Standings (ESPN cache, updated by scheduled Cloud Function) ──────
    match /standings/{sport} {
      allow read: if true;
      allow write: if false; // Cloud Function only
    }

    // ── Odds Cache (Cloud Function writes, clients read via callable) ────
    match /cache_odds/{sport} {
      allow read: if false; // clients use getSportsOdds callable, not direct reads
      allow write: if false;
    }

    // ── User Plans & Rate Limiting ───────────────────────────────────────
    match /users/{uid} {
      allow read:   if isSignedIn() && request.auth.uid == uid;
      allow create: if false; // Cloud Function creates these
      allow update: if false; // Cloud Function updates these
      allow delete: if false;
    }
  }
}
